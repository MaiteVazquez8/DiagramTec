# Usar al ejecutar: node scripts/build-hostinger.mjs
# O copiar a frontend/.env.production antes de pnpm run build

# Dominio principal (sin https://)
HOSTINGER_DOMAIN=tudominio.com

# API Node en subdominio (crear en hPanel → Dominios → Subdominios → api)
VITE_API_URL=https://api.tudominio.com
VITE_PHP_AUTH_URL=https://tudominio.com/php
