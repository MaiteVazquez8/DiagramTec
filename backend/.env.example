# Supabase (PostgreSQL) — obligatorio
# Dashboard → Settings → Database → Connection string → URI (Session pooler recomendado)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# SSL (dejar en true para Supabase; false solo en desarrollo local con Postgres sin SSL)
DB_SSL=true
DB_POOL_MAX=10

PORT=4002

JWT_SECRET=nuevaContraseña_superSegura_diagramtec

# URL del frontend en producción (Hostinger) — CORS en Node
FRONTEND_URL=https://tudominio.com

# URL pública de PHP en Hostinger
PHP_BACKEND_URL=https://tudominio.com/php
PHP_EXECUTABLE=php

# Email para recuperación de contraseña (Gmail: usar contraseña de aplicación)
EMAIL_USER=diagramtec@gmail.com
EMAIL_PASS=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
