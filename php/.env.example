# Google
GOOGLE_CLIENT_ID=secret_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=secret_google_client_id
# Google OAuth — debe coincidir con el servidor PHP que atiende el login
# PHP embebido (Node pnpm run dev en backend):
GOOGLE_CALLBACK_URL=http://localhost:8000/google_auth.php?action=callback
# Laragon/Apache (descomentar si usás Apache en lugar del PHP embebido):
# GOOGLE_CALLBACK_URL=http://localhost/diagram/DiagramTec/php/google_auth.php?action=callback

# Frontend URL (para redirigir tras login con Google)
FRONTEND_URL=http://localhost:5173