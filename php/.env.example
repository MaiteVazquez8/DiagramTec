# Carga automática desde backend/.env (misma DATABASE_URL de Supabase)
# Si necesitas variables solo de PHP, defínelas aquí.

# URL del frontend (CORS) — debe coincidir con FRONTEND_URL del backend
FRONTEND_URL=https://tudominio.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost/diagram/DiagramTec/php/google_auth.php?action=callback

# Frontend URL (redirección tras login con Google)
FRONTEND_URL=http://localhost:5173
